<Window x:Class="Desktop.Views.MainShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:Desktop.Converters"
        xmlns:pages="clr-namespace:Desktop.Views.Pages"
        xmlns:vm="clr-namespace:Desktop.ViewModels"
        Title="ALTI Hotel — Panel de Gestión"
        Height="768" Width="1280"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <converters:BoolToVisibilityConverter        x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <!-- DataTemplates ViewModel → Page -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <pages:DashboardPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BookingsViewModel}">
            <pages:BookingsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PaymentsViewModel}">
            <pages:PaymentsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RoomsViewModel}">
            <pages:RoomsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}">
            <pages:UsersPage/>
        </DataTemplate>

        <!-- Botón nav inactivo -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"                Value="Transparent"/>
            <Setter Property="Foreground"                Value="#666688"/>
            <Setter Property="BorderThickness"           Value="0"/>
            <Setter Property="Height"                    Value="48"/>
            <Setter Property="Cursor"                    Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                   Value="20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A1A3A"/>
                                <Setter Property="Foreground"                 Value="#AAAACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón nav activo -->
        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1A1A3A"
                                BorderThickness="3,0,0,0"
                                BorderBrush="#8B5FBF"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10">
        <Border.Background>
            <SolidColorBrush Color="#0F0F1E"/>
        </Border.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ════════════════════════════
                 SIDEBAR
            ════════════════════════════ -->
            <Border Grid.Column="0">
                <Border.Background>
                    <SolidColorBrush Color="#13132A"/>
                </Border.Background>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="20,0">
                        <TextBlock Text="ALTI"
                                   FontSize="24" FontWeight="Light"
                                   Foreground="White" FontFamily="Segoe UI Light"/>
                        <TextBlock Text="Hotel &amp; Resort"
                                   FontSize="9" Foreground="#8B5FBF" Margin="1,2,0,0"/>
                    </StackPanel>

                    <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom" Margin="16,0" Fill="#1E1E3A"/>

                    <!-- Nav links -->
                    <StackPanel Grid.Row="1" Margin="0,16,0,0">

                        <!-- Dashboard -->
                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="Dashboard">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMenu}" Value="Dashboard">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="#1A1A3A"
                                                                BorderThickness="3,0,0,0"
                                                                BorderBrush="#8B5FBF"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ViewDashboard" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Reservas -->
                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="Bookings">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMenu}" Value="Bookings">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="#1A1A3A"
                                                                BorderThickness="3,0,0,0"
                                                                BorderBrush="#8B5FBF"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CalendarClock" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Reservas" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Pagos -->
                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="Payments">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMenu}" Value="Payments">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="#1A1A3A"
                                                                BorderThickness="3,0,0,0"
                                                                BorderBrush="#8B5FBF"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CreditCard" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Pagos" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Habitaciones -->
                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="Rooms">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMenu}" Value="Rooms">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="#1A1A3A"
                                                                BorderThickness="3,0,0,0"
                                                                BorderBrush="#8B5FBF"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="BedKing" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Habitaciones" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Usuarios — solo admin -->
                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="Users"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMenu}" Value="Users">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="#1A1A3A"
                                                                BorderThickness="3,0,0,0"
                                                                BorderBrush="#8B5FBF"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountGroup" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Usuarios" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                    <!-- Separador -->
                    <Rectangle Grid.Row="2" Height="1" Margin="16,0" Fill="#1E1E3A"/>

                    <!-- Usuario + Logout -->
                    <Grid Grid.Row="3" Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="#2D1B69">
                            <TextBlock Text="{Binding UserInitial}"
                                       Foreground="#8B5FBF" FontSize="14" FontWeight="Medium"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                            <TextBlock Text="{Binding UserName}"
                                       Foreground="White" FontSize="12" FontWeight="Medium"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding UserRole}"
                                       Foreground="#666688" FontSize="10"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Command="{Binding LogoutCommand}"
                                Width="32" Height="32"
                                ToolTip="Cerrar sesión"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"   Value="Transparent"/>
                                    <Setter Property="Foreground"   Value="#666688"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1A1A3A"/>
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <materialDesign:PackIcon Kind="Logout" Width="16" Height="16"/>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- ════════════════════════════
                 CONTENIDO PRINCIPAL
            ════════════════════════════ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Topbar -->
                <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#1E1E3A" Background="#0F0F1E">
                    <Grid Margin="24,0" MouseLeftButtonDown="TopBar_MouseDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding CurrentPageTitle}"
                                   Foreground="White" FontSize="18"
                                   FontWeight="Light" FontFamily="Segoe UI Light"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Clock" Width="14" Height="14"
                                                     Foreground="#666688" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ClockText"
                                       Foreground="#666688" FontSize="12"
                                       Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Página activa -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentPage}"/>

                <!-- Loading -->
                <Grid Grid.Row="1"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.Background>
                        <SolidColorBrush Color="#80000000"/>
                    </Grid.Background>
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True" Width="48" Height="48"
                                 Foreground="#8B5FBF"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>