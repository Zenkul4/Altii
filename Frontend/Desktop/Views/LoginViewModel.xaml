<Window x:Class="Desktop.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:Desktop.Converters"
        Title="ALTI Hotel — Acceso"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <converters:BoolToVisibilityConverter        x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Window.Resources>

    <Border CornerRadius="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- ══ Lado izquierdo — decorativo ══ -->
            <Border Grid.Column="0" CornerRadius="12,0,0,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D0D1F" Offset="0"/>
                        <GradientStop Color="#1A1040" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="ALTI"
                               FontSize="72"
                               FontWeight="Light"
                               Foreground="White"
                               FontFamily="Segoe UI Light"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="HOTEL &amp; RESORT"
                               FontSize="13"
                               Foreground="#8B5FBF"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,32">
                        <TextBlock.LayoutTransform>
                            <ScaleTransform/>
                        </TextBlock.LayoutTransform>
                    </TextBlock>

                    <Rectangle Height="1" Width="120" Margin="0,0,0,32">
                        <Rectangle.Fill>
                            <SolidColorBrush Color="#2A2A4A"/>
                        </Rectangle.Fill>
                    </Rectangle>

                    <TextBlock Text="Panel de Gestión"
                               FontSize="14"
                               Foreground="#666688"
                               HorizontalAlignment="Center"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="Solo para personal autorizado"
                               FontSize="11"
                               Foreground="#444466"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- ══ Lado derecho — formulario ══ -->
            <Border Grid.Column="1" CornerRadius="0,12,12,0">
                <Border.Background>
                    <SolidColorBrush Color="#1E1E2E"/>
                </Border.Background>

                <Grid>
                    <!-- Formulario -->
                    <StackPanel VerticalAlignment="Center" Margin="48,0">

                        <!-- Botón cerrar -->
                        <Button HorizontalAlignment="Right"
                                Margin="0,-80,0,0"
                                Width="32" Height="32"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#666688"
                                Command="{Binding CloseCommand}"
                                Cursor="Hand"
                                ToolTip="Cerrar">
                            <TextBlock Text="✕" FontSize="14"/>
                        </Button>

                        <TextBlock Text="Bienvenido"
                                   FontSize="28"
                                   FontWeight="Light"
                                   Foreground="White"
                                   Margin="0,0,0,4"/>

                        <TextBlock Text="Ingrese sus credenciales para continuar"
                                   FontSize="12"
                                   Foreground="#666688"
                                   Margin="0,0,0,36"/>

                        <!-- Email -->
                        <TextBlock Text="CORREO ELECTRÓNICO"
                                   FontSize="10"
                                   Foreground="#666688"
                                   Margin="0,0,0,6"
                                   FontFamily="Segoe UI"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Height="44"
                                 Padding="12,10"
                                 FontSize="14"
                                 Foreground="White"
                                 CaretBrush="White"
                                 BorderThickness="1"
                                 BorderBrush="#333355"
                                 Background="#12122A"
                                 Margin="0,0,0,16">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter Property="BorderBrush" Value="#8B5FBF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Password -->
                        <TextBlock Text="CONTRASEÑA"
                                   FontSize="10"
                                   Foreground="#666688"
                                   Margin="0,0,0,6"
                                   FontFamily="Segoe UI"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Height="44"
                                     Padding="12,10"
                                     FontSize="14"
                                     Foreground="White"
                                     BorderThickness="1"
                                     BorderBrush="#333355"
                                     Background="#12122A"
                                     Margin="0,0,0,8"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>

                        <!-- Error -->
                        <Border Background="#3D1515"
                                BorderBrush="#7F1D1D"
                                BorderThickness="1"
                                Padding="12,8"
                                Margin="0,8,0,0"
                                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#FCA5A5"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Botón Login -->
                        <Button Content="{Binding LoginButtonText}"
                                Command="{Binding LoginCommand}"
                                Margin="0,24,0,0"
                                Height="48"
                                FontSize="13"
                                FontWeight="Medium"
                                BorderThickness="0"
                                Cursor="Hand"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <Button.Background>
                                <SolidColorBrush Color="#8B5FBF"/>
                            </Button.Background>
                            <Button.Foreground>
                                <SolidColorBrush Color="White"/>
                            </Button.Foreground>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="#7A4EAE"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.6"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <TextBlock Text="ALTI Hotel v1.0 — Programación 2"
                                   FontSize="10"
                                   Foreground="#333355"
                                   HorizontalAlignment="Center"
                                   Margin="0,40,0,0"/>
                    </StackPanel>

                    <!-- Loading overlay -->
                    <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.Background>
                            <SolidColorBrush Color="#80000000"/>
                        </Grid.Background>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True"
                                         Width="40" Height="40"
                                         Foreground="#8B5FBF"
                                         Style="{StaticResource MaterialDesignCircularProgressBar}"/>
                            <TextBlock Text="Verificando..."
                                       Foreground="#8B5FBF"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>

                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>