<UserControl x:Class="Desktop.Views.Pages.ServicesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Desktop.Converters"
             Background="#0F0F1E"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:StringToColorConverter x:Key="StrToColor"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Padding="24,16" BorderThickness="0,0,0,1" BorderBrush="#1E1E3A">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Servicios adicionales" Foreground="#666688" FontSize="13" VerticalAlignment="Center"/>

                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding StatusFilters}"
                              SelectedItem="{Binding FilterStatus}"
                              Width="120" Margin="0,0,8,0"
                              Background="#13132A" Foreground="White" BorderBrush="#2A2A4A" FontSize="13"/>

                    <Button Grid.Column="2" Command="{Binding ShowCreateCommand}"
                            Background="#8B5FBF" Foreground="White" BorderThickness="0"
                            Padding="16,8" Cursor="Hand" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Nuevo servicio" Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3" Command="{Binding LoadCommand}"
                            Background="#1A1A3A" BorderThickness="0" Foreground="#8B5FBF"
                            Cursor="Hand" Padding="10,8" ToolTip="Refrescar">
                        <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Messages -->
            <StackPanel Grid.Row="1">
                <Border Background="#1A3A1A" Padding="12,8" Margin="16,8,16,0"
                        Visibility="{Binding SuccessMessage, Converter={StaticResource BoolToVis}, ConverterParameter=notempty}">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="#86EFAC" FontSize="13"/>
                </Border>
                <Border Background="#3D1515" Padding="12,8" Margin="16,8,16,0"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="13"/>
                </Border>
            </StackPanel>

            <!-- List -->
            <ListView Grid.Row="2" ItemsSource="{Binding Services}" SelectedItem="{Binding Selected}"
                      Background="Transparent" BorderThickness="0" Margin="16,8"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0,4"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#13132A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1A1040"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12,10" BorderThickness="0,0,0,1" BorderBrush="#1A1A3A">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,12,0" VerticalAlignment="Center"
                                         Fill="{Binding StatusColor, Converter={StaticResource StrToColor}}"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="14" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding Description}" Foreground="#666688" FontSize="11" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat='${0:N2}'}"
                                           Foreground="#8B5FBF" FontSize="15" FontWeight="Medium"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>

                                <Border Grid.Column="3" Padding="6,2" VerticalAlignment="Center">
                                    <Border.Background>
                                        <SolidColorBrush Color="#1A1A3A"/>
                                    </Border.Background>
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="10"
                                               Foreground="{Binding StatusColor, Converter={StaticResource StrToColor}}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Right panel -->
        <Border Grid.Column="1" BorderThickness="1,0,0,0" BorderBrush="#1E1E3A" Background="#0D0D20">
            <Grid>
                <!-- Detail -->
                <Grid Visibility="{Binding ShowDetail, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,16" BorderThickness="0,0,0,1" BorderBrush="#1E1E3A">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Selected.Name}" Foreground="White" FontSize="18" FontWeight="Medium"/>
                            <Button Grid.Column="1" Command="{Binding CloseDetailCommand}"
                                    Background="Transparent" BorderThickness="0" Foreground="#666688" Cursor="Hand">
                                <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Precio" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Selected.Price, StringFormat='${0:N2}'}" Foreground="#8B5FBF" FontSize="15" FontWeight="Medium"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Estado" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Selected.StatusLabel}"
                                           Foreground="{Binding Selected.StatusColor, Converter={StaticResource StrToColor}}" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,4" Visibility="{Binding Selected.Description, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Descripción" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Selected.Description}" Foreground="#AAAACC" FontSize="12" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Padding="20,16" BorderThickness="0,1,0,0" BorderBrush="#1E1E3A">
                        <StackPanel>
                            <Button Command="{Binding ShowEditCommand}" Height="40" Margin="0,4"
                                    Background="#1D4ED8" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="13">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Editar servicio" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DeactivateCommand}"
                                    Visibility="{Binding CanDeactivate, Converter={StaticResource BoolToVis}}"
                                    Height="40" Margin="0,4" Background="Transparent" Foreground="#EF4444"
                                    BorderThickness="1" BorderBrush="#EF4444" Cursor="Hand" FontSize="13" Content="Desactivar"/>
                            <Button Command="{Binding ActivateCommand}"
                                    Visibility="{Binding CanActivate, Converter={StaticResource BoolToVis}}"
                                    Height="40" Margin="0,4" Background="#0D7A4A" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="13" Content="Activar"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Create/Edit form -->
                <Grid Visibility="{Binding ShowCreateForm, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,16" BorderThickness="0,0,0,1" BorderBrush="#1E1E3A">
                        <TextBlock Foreground="White" FontSize="18" FontWeight="Medium">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Nuevo servicio"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Text" Value="Editar servicio"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <TextBlock Text="Nombre" Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#13132A" Foreground="White" BorderBrush="#2A2A4A"
                                     Padding="8" FontSize="13" Margin="0,0,0,12">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="IsReadOnly" Value="True"/>
                                                <Setter Property="Foreground" Value="#666688"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <TextBlock Text="Precio ($)" Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FormPrice, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#13132A" Foreground="White" BorderBrush="#2A2A4A"
                                     Padding="8" FontSize="13" Margin="0,0,0,12"/>

                            <TextBlock Text="Descripción (opcional)" Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#13132A" Foreground="White" BorderBrush="#2A2A4A"
                                     Padding="8" FontSize="13" TextWrapping="Wrap"
                                     AcceptsReturn="True" Height="80"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="20,0,20,16">
                        <Button Command="{Binding SaveCommand}" Height="40" Margin="0,4"
                                Background="#8B5FBF" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="13">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Crear servicio"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Text" Value="Guardar cambios"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                        <Button Command="{Binding CancelCreateCommand}" Height="36" Margin="0,4"
                                Background="Transparent" Foreground="#666688" BorderThickness="1" BorderBrush="#2A2A4A" Cursor="Hand" FontSize="12">
                            <TextBlock Text="Cancelar"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Loading -->
        <Grid Grid.ColumnSpan="2" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Grid.Background>
                <SolidColorBrush Color="#80000000"/>
            </Grid.Background>
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                         IsIndeterminate="True" Width="48" Height="48" Foreground="#8B5FBF"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>