<UserControl x:Class="Desktop.Views.Pages.UsersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Desktop.Converters"
             Background="#0F0F1E"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter        x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="24,16" BorderThickness="0,0,0,1" BorderBrush="#1E1E3A">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding RoleFilters}"
                              SelectedItem="{Binding FilterRole}"
                              Width="200" HorizontalAlignment="Left"
                              Foreground="White" Background="#13132A"
                              BorderBrush="#2A2A4A" FontSize="13"/>
                    <Button Grid.Column="1" Command="{Binding ShowCreateCommand}"
                            Margin="8,0" Background="#8B5FBF" BorderThickness="0"
                            Foreground="White" Cursor="Hand" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountPlus" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Nuevo usuario" Margin="6,0,0,0" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Command="{Binding LoadCommand}"
                            Background="#1A1A3A" BorderThickness="0"
                            Foreground="#8B5FBF" Cursor="Hand" Padding="10,8">
                        <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1">
                <Border Background="#1A3A1A" Padding="12,8" Margin="16,8,16,0"
                        Visibility="{Binding SuccessMessage,
                            Converter={StaticResource BoolToVis}, ConverterParameter=notempty}">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="#86EFAC" FontSize="13"/>
                </Border>
                <Border Background="#3D1515" Padding="12,8" Margin="16,8,16,0"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="13"/>
                </Border>
            </StackPanel>

            <ListView Grid.Row="2"
                      ItemsSource="{Binding Users}"
                      SelectedItem="{Binding Selected}"
                      Background="Transparent" BorderThickness="0"
                      Margin="16,8"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"         Value="0,4"/>
                        <Setter Property="Cursor"          Value="Hand"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#13132A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1A1040"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12,10" BorderThickness="0,0,0,1" BorderBrush="#1A1A3A">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="36" Height="36"
                                        CornerRadius="18" Background="#2D1B69" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Initial}"
                                               Foreground="#8B5FBF" FontSize="14" FontWeight="Medium"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding FullName}"
                                               Foreground="White" FontSize="14" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding Email}"
                                               Foreground="#666688" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="2" Padding="8,4" Background="#1A1A3A" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding RoleLabel}" Foreground="#8B5FBF" FontSize="11"/>
                                </Border>
                                <Border Grid.Column="3" Padding="8,4" Background="#1A1A3A">
                                    <TextBlock FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"       Value="Activo"/>
                                                <Setter Property="Foreground" Value="#10B981"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Text"       Value="Inactivo"/>
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border Grid.Row="3" Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="#1E1E3A">
                <TextBlock Foreground="#444466" FontSize="11">
                    <Run Text="{Binding Users.Count, Mode=OneWay}"/>
                    <Run Text=" usuarios"/>
                </TextBlock>
            </Border>
        </Grid>

        <Border Grid.Column="1" BorderThickness="1,0,0,0" BorderBrush="#1E1E3A">
            <Border.Background>
                <SolidColorBrush Color="#0D0D20"/>
            </Border.Background>
            <Grid>
                <Grid Visibility="{Binding ShowDetail, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,16" BorderThickness="0,0,0,1" BorderBrush="#1E1E3A">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="40" Height="40" CornerRadius="20"
                                        Background="#2D1B69" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Selected.Initial}"
                                               Foreground="#8B5FBF" FontSize="16" FontWeight="Medium"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Selected.FullName}"
                                               Foreground="White" FontSize="15" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding Selected.RoleLabel}"
                                               Foreground="#8B5FBF" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding CloseDetailCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#666688" Cursor="Hand">
                                <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <TextBlock Text="INFORMACIÓN" Foreground="#444466" FontSize="10" Margin="0,0,0,8"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Email" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Selected.Email}"
                                           Foreground="White" FontSize="12" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Teléfono" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Selected.Phone, TargetNullValue='—'}"
                                           Foreground="White" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Creado" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Selected.CreatedAt, StringFormat='{}{0:dd/MM/yyyy}'}"
                                           Foreground="White" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Estado" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1" FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="Activo"/>
                                            <Setter Property="Foreground" Value="#10B981"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Selected.IsActive}" Value="False">
                                                    <Setter Property="Text"       Value="Inactivo"/>
                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Padding="20,16" BorderThickness="0,1,0,0" BorderBrush="#1E1E3A">
                        <StackPanel>
                            <Button Command="{Binding DeactivateCommand}"
                                    Visibility="{Binding CanDeactivate, Converter={StaticResource BoolToVis}}"
                                    Height="38" Background="Transparent" Foreground="#EF4444"
                                    BorderThickness="1" BorderBrush="#EF4444" Cursor="Hand" FontSize="12">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3D1515"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountOff" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Desactivar usuario" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ReactivateCommand}"
                                    Visibility="{Binding CanReactivate, Converter={StaticResource BoolToVis}}"
                                    Height="38" Margin="0,6,0,0" Background="#0D7A4A" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="12">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountCheck" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Reactivar usuario" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding ShowCreateForm, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,16" BorderThickness="0,0,0,1" BorderBrush="#1E1E3A">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Nuevo Usuario" Foreground="White" FontSize="16" FontWeight="Medium"/>
                            <Button Grid.Column="1" Command="{Binding CloseCreateFormCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#666688" Cursor="Hand">
                                <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <TextBlock Text="Nombre *"    Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <Border Background="#13132A" BorderBrush="#2A2A4A" BorderThickness="1" Padding="10,8" Margin="0,0,0,12">
                                <TextBox Text="{Binding FormFirstName, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13"/>
                            </Border>
                            <TextBlock Text="Apellido *"  Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <Border Background="#13132A" BorderBrush="#2A2A4A" BorderThickness="1" Padding="10,8" Margin="0,0,0,12">
                                <TextBox Text="{Binding FormLastName, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13"/>
                            </Border>
                            <TextBlock Text="Email *"     Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <Border Background="#13132A" BorderBrush="#2A2A4A" BorderThickness="1" Padding="10,8" Margin="0,0,0,12">
                                <TextBox Text="{Binding FormEmail, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13"/>
                            </Border>
                            <TextBlock Text="Contraseña *" Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <Border Background="#13132A" BorderBrush="#2A2A4A" BorderThickness="1" Padding="10,8" Margin="0,0,0,12">
                                <PasswordBox x:Name="PwdBox"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="White" FontSize="13"
                                             PasswordChanged="PwdBox_PasswordChanged"/>
                            </Border>
                            <TextBlock Text="Teléfono"    Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <Border Background="#13132A" BorderBrush="#2A2A4A" BorderThickness="1" Padding="10,8" Margin="0,0,0,12">
                                <TextBox Text="{Binding FormPhone, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13"/>
                            </Border>
                            <TextBlock Text="Rol *"       Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding RoleOptions}"
                                      SelectedIndex="{Binding FormRole}"
                                      Margin="0,0,0,12" Foreground="White"
                                      Background="#13132A" BorderBrush="#2A2A4A" FontSize="13"/>
                            <Border Background="#3D1515" Padding="12,8"
                                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5"
                                           FontSize="12" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Padding="20,16" BorderThickness="0,1,0,0" BorderBrush="#1E1E3A">
                        <Button Command="{Binding CreateCommand}"
                                Height="42" Background="#8B5FBF" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="13" FontWeight="Medium">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#7A4EAE"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountPlus" Width="16" Height="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Crear usuario" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.ColumnSpan="2"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Grid.Background>
                <SolidColorBrush Color="#80000000"/>
            </Grid.Background>
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                         IsIndeterminate="True" Width="48" Height="48"
                         Foreground="#8B5FBF"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>