<UserControl x:Class="Desktop.Views.Pages.BookingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Desktop.Converters"
             Background="#0F0F1E"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter        x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <converters:StringToColorConverter           x:Key="StrToColor"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380" x:Name="DetailCol"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="24,16" BorderThickness="0,0,0,1" BorderBrush="#1E1E3A">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#13132A" BorderBrush="#2A2A4A"
                            BorderThickness="1" Padding="12,8" MaxWidth="320"
                            HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding SearchCode, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="White" FontSize="13"
                                     materialDesign:HintAssist.Hint="Buscar por código RES-..."
                                     materialDesign:HintAssist.Foreground="#666688">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SearchByCodeCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" Command="{Binding SearchByCodeCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#8B5FBF" Cursor="Hand" Padding="4">
                                <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Filtro de estado -->
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding StatusFilters}"
                              SelectedItem="{Binding FilterStatus}"
                              Margin="12,0"
                              Width="160"
                              Foreground="White"
                              Background="#13132A"
                              BorderBrush="#2A2A4A"
                              FontSize="13"/>

                    <!-- Botón refrescar -->
                    <Button Grid.Column="2"
                            Command="{Binding LoadCommand}"
                            Background="#1A1A3A" BorderThickness="0"
                            Foreground="#8B5FBF" Cursor="Hand"
                            Padding="10,8" ToolTip="Refrescar">
                        <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Mensajes -->
            <StackPanel Grid.Row="1">
                <Border Background="#1A3A1A" Padding="12,8" Margin="16,8,16,0"
                        Visibility="{Binding SuccessMessage, Converter={StaticResource BoolToVis},
                                     ConverterParameter=notempty}">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="#86EFAC" FontSize="13"/>
                </Border>
                <Border Background="#3D1515" Padding="12,8" Margin="16,8,16,0"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="13"/>
                </Border>
            </StackPanel>

            <!-- Lista -->
            <ListView Grid.Row="2"
                      ItemsSource="{Binding Bookings}"
                      SelectedItem="{Binding Selected}"
                      Background="Transparent"
                      BorderThickness="0"
                      Margin="16,8"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background"       Value="Transparent"/>
                        <Setter Property="BorderThickness"  Value="0"/>
                        <Setter Property="Padding"          Value="0,4"/>
                        <Setter Property="Cursor"           Value="Hand"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#13132A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1A1040"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="Transparent" Padding="12,10"
                                BorderThickness="0,0,0,1" BorderBrush="#1A1A3A">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <!-- Status dot -->
                                <Ellipse Grid.Column="0" Width="10" Height="10"
                                         Margin="0,0,12,0" VerticalAlignment="Center"
                                         Fill="{Binding StatusColor, Converter={StaticResource StrToColor}}"/>

                                <!-- Info -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Code}"
                                               Foreground="White" FontSize="14"
                                               FontWeight="Medium"/>
                                    <TextBlock Foreground="#666688" FontSize="12" Margin="0,2,0,0">
                                        <Run Text="{Binding GuestFullName, Mode=OneWay }"/>
                                        <Run Text=" · Hab."/>
                                        <Run Text="{Binding RoomNumber, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#555577" FontSize="11" Margin="0,2,0,0">
                                        <Run Text="{Binding CheckInDate, Mode=OneWay}"/>
                                        <Run Text=" → "/>
                                        <Run Text="{Binding CheckOutDate, Mode=OneWay}"/>
                                        <Run Text=" ("/>
                                        <Run Text="{Binding Nights, Mode=OneWay}"/>
                                        <Run Text=" noches)"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Total -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="{Binding TotalPrice, StringFormat='${0:N2}'}"
                                               Foreground="#8B5FBF" FontSize="15"
                                               FontWeight="Medium" TextAlignment="Right"/>
                                </StackPanel>

                                <!-- Estado badge -->
                                <Border Grid.Column="3" VerticalAlignment="Center"
                                        Padding="8,4" HorizontalAlignment="Right">
                                    <Border.Background>
                                        <SolidColorBrush Color="#1A1A3A"/>
                                    </Border.Background>
                                    <TextBlock Text="{Binding StatusLabel}"
                                               FontSize="11" FontWeight="Medium"
                                               Foreground="{Binding StatusColor,
                                                   Converter={StaticResource StrToColor}}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Footer info -->
            <Border Grid.Row="3" Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="#1E1E3A">
                <TextBlock Foreground="#444466" FontSize="11">
                    <Run Text="{Binding Bookings.Count, Mode=OneWay}"/>
                    <Run Text=" reservas activas"/>
                </TextBlock>
            </Border>
        </Grid>

        <!-- ══════════════════════════════
             PANEL DE DETALLE
        ══════════════════════════════ -->
        <Border Grid.Column="1"
                BorderThickness="1,0,0,0"
                BorderBrush="#1E1E3A"
                Visibility="{Binding ShowDetail, Converter={StaticResource BoolToVis}}">
            <Border.Background>
                <SolidColorBrush Color="#0D0D20"/>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header del detalle -->
                <Border Grid.Row="0" Padding="20,16" BorderThickness="0,0,0,1" BorderBrush="#1E1E3A">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Selected.Code}"
                                       Foreground="White" FontSize="18"
                                       FontWeight="Medium"/>
                            <TextBlock Foreground="{Binding Selected.StatusColor,
                                           Converter={StaticResource StrToColor}}"
                                       FontSize="12" Margin="0,2,0,0">
                                <Run Text="{Binding Selected.StatusLabel, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Command="{Binding CloseDetailCommand}"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#666688" Cursor="Hand">
                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Datos del detalle -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">

                        <!-- Sección huésped -->
                        <TextBlock Text="HUÉSPED" Foreground="#444466"
                                   FontSize="10" Margin="0,0,0,8"/>
                        <StackPanel Margin="0,0,0,20">
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Nombre" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Selected.GuestFullName}"
                                           Foreground="White" FontSize="12"/>
                            </Grid>
                        </StackPanel>

                        <!-- Sección habitación -->
                        <TextBlock Text="HABITACIÓN" Foreground="#444466"
                                   FontSize="10" Margin="0,0,0,8"/>
                        <StackPanel Margin="0,0,0,20">
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Número" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Selected.RoomNumber}"
                                           Foreground="White" FontSize="12"/>
                            </Grid>
                        </StackPanel>

                        <!-- Sección fechas -->
                        <TextBlock Text="FECHAS" Foreground="#444466"
                                   FontSize="10" Margin="0,0,0,8"/>
                        <StackPanel Margin="0,0,0,20">
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Check-In" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Selected.CheckInDate}"
                                           Foreground="White" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Check-Out" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Selected.CheckOutDate}"
                                           Foreground="White" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Noches" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Selected.Nights}"
                                           Foreground="White" FontSize="12"/>
                            </Grid>
                        </StackPanel>

                        <!-- Sección precios -->
                        <TextBlock Text="PRECIO" Foreground="#444466"
                                   FontSize="10" Margin="0,0,0,8"/>
                        <StackPanel Margin="0,0,0,20">
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Por noche" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Selected.PricePerNight, StringFormat='${0:N2}'}"
                                           Foreground="White" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Total" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Selected.TotalPrice, StringFormat='${0:N2}'}"
                                           Foreground="#8B5FBF" FontSize="15" FontWeight="Medium"/>
                            </Grid>
                        </StackPanel>

                        <!-- Notas -->
                        <TextBlock Text="NOTAS" Foreground="#444466"
                                   FontSize="10" Margin="0,0,0,8"
                                   Visibility="{Binding Selected.Notes,
                                       Converter={StaticResource BoolToVis}}"/>
                        <Border Background="#13132A" Padding="12" Margin="0,0,0,20"
                                Visibility="{Binding Selected.Notes,
                                    Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding Selected.Notes}"
                                       Foreground="#AAAACC" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Acciones -->
                <Border Grid.Row="2" Padding="20,16" BorderThickness="0,1,0,0" BorderBrush="#1E1E3A">
                    <StackPanel>

                        <!-- Pago en efectivo (PendingPayment) -->
                        <Button Command="{Binding CashPaymentCommand}"
        Visibility="{Binding CanCashPayment, Converter={StaticResource BoolToVis}}"
        Height="40" Margin="0,4" Cursor="Hand"
        Background="#B8860B" Foreground="White"
        BorderThickness="0" FontSize="13" FontWeight="Medium">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#996F0A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Cash" Width="16" Height="16"
                                 VerticalAlignment="Center"/>
                                <TextBlock Text="Pago en efectivo" Margin="8,0,0,0"
                   VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Confirmar (PendingPayment) -->
                        <Button Command="{Binding ConfirmCommand}"
                                Visibility="{Binding CanConfirm, Converter={StaticResource BoolToVis}}"
                                Height="40" Margin="0,4" Cursor="Hand"
                                Background="#8B5FBF" Foreground="White"
                                BorderThickness="0" FontSize="13" FontWeight="Medium">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#7A4EAE"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircle" Width="16" Height="16"
                                                         VerticalAlignment="Center"/>
                                <TextBlock Text="Confirmar reserva" Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Check-In (Confirmed) -->
                        <Button Command="{Binding CheckInCommand}"
                                Visibility="{Binding CanCheckIn, Converter={StaticResource BoolToVis}}"
                                Height="40" Margin="0,4" Cursor="Hand"
                                Background="#0D7A4A" Foreground="White"
                                BorderThickness="0" FontSize="13" FontWeight="Medium">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#0A5E38"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Login" Width="16" Height="16"
                                                         VerticalAlignment="Center"/>
                                <TextBlock Text="Registrar Check-In" Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Check-Out (CheckedIn) -->
                        <Button Command="{Binding CheckOutCommand}"
                                Visibility="{Binding CanCheckOut, Converter={StaticResource BoolToVis}}"
                                Height="40" Margin="0,4" Cursor="Hand"
                                Background="#1D4ED8" Foreground="White"
                                BorderThickness="0" FontSize="13" FontWeight="Medium">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1639A8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Logout" Width="16" Height="16"
                                                         VerticalAlignment="Center"/>
                                <TextBlock Text="Registrar Check-Out" Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Cancelar -->
                        <Button Command="{Binding CancelCommand}"
                                Visibility="{Binding CanCancel, Converter={StaticResource BoolToVis}}"
                                Height="40" Margin="0,4" Cursor="Hand"
                                Background="Transparent" Foreground="#EF4444"
                                BorderThickness="1" BorderBrush="#EF4444"
                                FontSize="13" FontWeight="Medium">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#3D1515"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Cancel" Width="16" Height="16"
                                                         VerticalAlignment="Center"/>
                                <TextBlock Text="Cancelar reserva" Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Grid Grid.ColumnSpan="2"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Grid.Background>
                <SolidColorBrush Color="#80000000"/>
            </Grid.Background>
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                         IsIndeterminate="True" Width="48" Height="48"
                         Foreground="#8B5FBF"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>