<UserControl x:Class="Desktop.Views.Pages.RoomsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Desktop.Converters"
             Background="#0F0F1E"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter        x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <converters:StringToColorConverter           x:Key="StrToColor"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="24,16" BorderThickness="0,0,0,1" BorderBrush="#1E1E3A">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding StatusFilters}"
                              SelectedItem="{Binding FilterStatus}"
                              Width="200" HorizontalAlignment="Left"
                              Foreground="White" Background="#13132A"
                              BorderBrush="#2A2A4A" FontSize="13"/>
                    <Button Grid.Column="1" Command="{Binding ShowCreateCommand}"
                            Margin="8,0" Background="#8B5FBF" BorderThickness="0"
                            Foreground="White" Cursor="Hand" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Nueva habitación" Margin="6,0,0,0" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Command="{Binding LoadCommand}"
                            Background="#1A1A3A" BorderThickness="0"
                            Foreground="#8B5FBF" Cursor="Hand" Padding="10,8">
                        <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1">
                <Border Background="#1A3A1A" Padding="12,8" Margin="16,8,16,0"
                        Visibility="{Binding SuccessMessage,
                            Converter={StaticResource BoolToVis}, ConverterParameter=notempty}">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="#86EFAC" FontSize="13"/>
                </Border>
                <Border Background="#3D1515" Padding="12,8" Margin="16,8,16,0"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="13"/>
                </Border>
            </StackPanel>

            <ListView Grid.Row="2"
                      ItemsSource="{Binding Rooms}"
                      SelectedItem="{Binding Selected}"
                      Background="Transparent" BorderThickness="0"
                      Margin="16,8"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"         Value="0,4"/>
                        <Setter Property="Cursor"          Value="Hand"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#13132A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1A1040"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12,10" BorderThickness="0,0,0,1" BorderBrush="#1A1A3A">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="10" Height="10"
                                         Margin="0,0,12,0" VerticalAlignment="Center"
                                         Fill="{Binding StatusColor, Converter={StaticResource StrToColor}, Mode=OneWay}"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Foreground="White" FontSize="14" FontWeight="Medium">
                                        <Run Text="Hab. "/>
                                        <Run Text="{Binding Number, Mode=OneWay}"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding TypeLabel, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#666688" FontSize="12" Margin="0,2,0,0">
                                        <Run Text="Piso "/>
                                        <Run Text="{Binding Floor, Mode=OneWay}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding Capacity, Mode=OneWay}"/>
                                        <Run Text=" personas"/>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding BasePrice, StringFormat='${0:N2}', Mode=OneWay}"
                                           Foreground="#8B5FBF" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <Border Grid.Column="3" Padding="8,4" Background="#1A1A3A">
                                    <TextBlock Text="{Binding StatusLabel, Mode=OneWay}" FontSize="11"
                                               Foreground="{Binding StatusColor, Converter={StaticResource StrToColor}, Mode=OneWay}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border Grid.Row="3" Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="#1E1E3A">
                <TextBlock Foreground="#444466" FontSize="11">
                    <Run Text="{Binding Rooms.Count, Mode=OneWay}"/>
                    <Run Text=" habitaciones"/>
                </TextBlock>
            </Border>
        </Grid>

        <Border Grid.Column="1" BorderThickness="1,0,0,0" BorderBrush="#1E1E3A">
            <Border.Background>
                <SolidColorBrush Color="#0D0D20"/>
            </Border.Background>
            <Grid>
                <Grid Visibility="{Binding ShowDetail, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,16" BorderThickness="0,0,0,1" BorderBrush="#1E1E3A">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Foreground="White" FontSize="18" FontWeight="Medium">
                                    <Run Text="Habitación "/>
                                    <Run Text="{Binding Selected.Number, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Foreground="{Binding Selected.StatusColor,
                                               Converter={StaticResource StrToColor}, Mode=OneWay}"
                                           FontSize="12" Margin="0,2,0,0"
                                           Text="{Binding Selected.StatusLabel, Mode=OneWay}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding CloseDetailCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#666688" Cursor="Hand">
                                <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <TextBlock Text="INFORMACIÓN" Foreground="#444466" FontSize="10" Margin="0,0,0,8"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tipo" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Selected.TypeLabel, Mode=OneWay}"
                                           Foreground="White" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Piso" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Selected.Floor, Mode=OneWay}"
                                           Foreground="White" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Capacidad" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Selected.Capacity, Mode=OneWay}"
                                           Foreground="White" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Precio/noche" Foreground="#666688" FontSize="12"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Selected.BasePrice, StringFormat='${0:N2}', Mode=OneWay}"
                                           Foreground="#8B5FBF" FontSize="13" FontWeight="Medium"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Padding="20,16" BorderThickness="0,1,0,0" BorderBrush="#1E1E3A">
                        <StackPanel>
                            <Button Command="{Binding MarkAvailableCommand}"
                                    Visibility="{Binding CanMarkAvail, Converter={StaticResource BoolToVis}}"
                                    Height="38" Margin="0,3" Background="#0D7A4A" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="12">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckCircle" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Marcar disponible" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding MarkOccupiedCommand}"
                                    Visibility="{Binding CanMarkOccupied, Converter={StaticResource BoolToVis}}"
                                    Height="38" Margin="0,3" Background="#1D4ED8" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="12">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="BedKing" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Marcar ocupada" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding MarkCleaningCommand}"
                                    Visibility="{Binding CanMarkCleaning, Converter={StaticResource BoolToVis}}"
                                    Height="38" Margin="0,3" Background="#92400E" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="12">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Broom" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Marcar en limpieza" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding MarkBlockedCommand}"
                                    Visibility="{Binding CanMarkBlocked, Converter={StaticResource BoolToVis}}"
                                    Height="38" Margin="0,3" Background="#7C3AED" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="12">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Lock" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Bloquear habitación" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ReleaseBlockCommand}"
                                    Visibility="{Binding CanReleaseBlock, Converter={StaticResource BoolToVis}}"
                                    Height="38" Margin="0,3" Background="#1D4ED8" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="12">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="LockOpen" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Liberar bloqueo" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding DisableCommand}"
                                    Visibility="{Binding CanDisable, Converter={StaticResource BoolToVis}}"
                                    Height="38" Margin="0,3" Background="Transparent" Foreground="#EF4444"
                                    BorderThickness="1" BorderBrush="#EF4444" Cursor="Hand" FontSize="12">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3D1515"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Cancel" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Desactivar habitación" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding EnableCommand}"
                                    Visibility="{Binding CanEnable, Converter={StaticResource BoolToVis}}"
                                    Height="38" Margin="0,3" Background="#0D7A4A" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="12">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Power" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Activar habitación" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding ShowCreateForm, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,16" BorderThickness="0,0,0,1" BorderBrush="#1E1E3A">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Nueva Habitación" Foreground="White" FontSize="16" FontWeight="Medium"/>
                            <Button Grid.Column="1" Command="{Binding CloseCreateFormCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#666688" Cursor="Hand">
                                <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <TextBlock Text="Número *" Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <Border Background="#13132A" BorderBrush="#2A2A4A" BorderThickness="1" Padding="10,8" Margin="0,0,0,14">
                                <TextBox Text="{Binding FormNumber, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13"/>
                            </Border>
                            <TextBlock Text="Tipo *" Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding RoomTypes}"
                                      SelectedItem="{Binding FormType}"
                                      Margin="0,0,0,14" Foreground="White"
                                      Background="#13132A" BorderBrush="#2A2A4A" FontSize="13"/>
                            <TextBlock Text="Piso *" Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <Border Background="#13132A" BorderBrush="#2A2A4A" BorderThickness="1" Padding="10,8" Margin="0,0,0,14">
                                <TextBox Text="{Binding FormFloor, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13"/>
                            </Border>
                            <TextBlock Text="Capacidad *" Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <Border Background="#13132A" BorderBrush="#2A2A4A" BorderThickness="1" Padding="10,8" Margin="0,0,0,14">
                                <TextBox Text="{Binding FormCapacity, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13"/>
                            </Border>
                            <TextBlock Text="Precio por noche *" Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <Border Background="#13132A" BorderBrush="#2A2A4A" BorderThickness="1" Padding="10,8" Margin="0,0,0,14">
                                <TextBox Text="{Binding FormBasePrice, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13"/>
                            </Border>
                            <TextBlock Text="Descripción" Foreground="#666688" FontSize="11" Margin="0,0,0,4"/>
                            <Border Background="#13132A" BorderBrush="#2A2A4A" BorderThickness="1" Padding="10,8">
                                <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0" Foreground="White"
                                         FontSize="13" TextWrapping="Wrap" MinHeight="60" MaxLines="4"/>
                            </Border>
                            <Border Background="#3D1515" Padding="12,8" Margin="0,12,0,0"
                                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5"
                                           FontSize="12" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Padding="20,16" BorderThickness="0,1,0,0" BorderBrush="#1E1E3A">
                        <Button Command="{Binding CreateCommand}"
                                Height="42" Background="#8B5FBF" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="13" FontWeight="Medium">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#7A4EAE"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Crear habitación" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.ColumnSpan="2"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Grid.Background>
                <SolidColorBrush Color="#80000000"/>
            </Grid.Background>
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                         IsIndeterminate="True" Width="48" Height="48"
                         Foreground="#8B5FBF"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>